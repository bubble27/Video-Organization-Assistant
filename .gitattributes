# Normalize line endings; shell launchers must stay LF so macOS can run them
* text=auto
*.command text eol=lf
*.sh text eol=lf
# the .app launcher has no extension but must stay LF (CRLF breaks the shebang)
"Video Organizer.app/Contents/MacOS/run" text eol=lf
*.py text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
